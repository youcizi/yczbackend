{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-plugins.mjs && astro dev",
    "start": "node scripts/sync-plugins.mjs && astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "pnpm build && wrangler deploy",
    "test:unit": "vitest run src/tests",
    "test:audit": "vitest run src/tests/integration/import-audit.test.ts",
    "test": "pnpm test:audit && pnpm test:unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check-all": "pnpm test:unit --coverage && pnpm test:e2e"
  },
