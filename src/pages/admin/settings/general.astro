---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { GeneralSettings } from '../../../components/admin/GeneralSettings';
import { createDbClient } from '../../../db';
import { getAdminPermissions } from '../../../lib/rbac';

const user = Astro.locals.user;
let DB: any;
try {
  // @ts-ignore
  const cf = await import('cloudflare:workers');
  DB = cf.env.DB;
} catch (e) {
  DB = (Astro.locals as any).runtime?.DB;
}
const db = await createDbClient(DB);
const permissions = await getAdminPermissions(db, user?.id);

// NOTE: 常规设置使用独立的 settings.general 权限，无需 role.manage 级别
if (!permissions.includes('settings.general') && !permissions.includes('*')) {
  return Astro.redirect('/admin');
}
---

<DashboardLayout title="常规设置">
  <div class="mb-6">
    <div class="flex items-center gap-2 text-sm text-slate-500 mb-2">
      <a href="/admin" class="hover:text-blue-600">管理后台</a>
      <span>/</span>
      <span class="text-slate-800 font-medium">配置中心</span>
      <span>/</span>
      <span class="text-slate-800 font-medium">常规设置</span>
    </div>
  </div>
  
  <GeneralSettings client:load />
</DashboardLayout>
