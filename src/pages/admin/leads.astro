---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { LeadsCenter } from '../../components/admin/LeadsCenter';
import { createDbClient } from '../../db';
import { getAdminPermissions } from '../../lib/rbac';

const user = Astro.locals.user;
let DB: any;
try {
  // @ts-ignore
  const cf = await import('cloudflare:workers');
  DB = cf.env.DB;
} catch (e) {
  DB = (Astro.locals as any).runtime?.DB;
}
const db = await createDbClient(DB);
const permissions = await getAdminPermissions(db, user?.id);

// NOTE: 线索中心页面使用独立的 leads.view 权限，而非全局的 site.view
if (!permissions.includes('leads.view') && !permissions.includes('*')) {
  return Astro.redirect('/admin');
}
---

<DashboardLayout title="线索中心 (CRM Leads)">
  <div class="mb-6">
    <div class="flex items-center gap-2 text-sm text-slate-500 mb-2">
      <a href="/admin" class="hover:text-blue-600">管理后台</a>
      <span>/</span>
      <span class="text-slate-800 font-medium font-bold">线索中心</span>
    </div>
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">CRM 线索聚合与访客追踪</h1>
      <div class="flex gap-2">
         {/* 可以增加导出 CSV 等功能 */}
      </div>
    </div>
  </div>
  
  <LeadsCenter client:load />
</DashboardLayout>
