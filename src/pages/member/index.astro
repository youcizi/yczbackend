---
import { App } from '../../member-app/App';
// @ts-ignore
import { env } from 'cloudflare:workers';

const title = "会员中心 - 参考实现";

// 获取 Turnstile Site Key (开发环境自动降级为测试 Key 以避免 110200 错误)
const isLocal = Astro.url.hostname === 'localhost' || Astro.url.hostname === '127.0.0.1';
const siteKey = isLocal ? "1x00000000000000000000AA" : (env?.TURNSTILE_SITE_KEY || "");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Member Center Reference Implementation" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    
    <script is:inline define:vars={{ siteKey }}>
      window.TURNSTILE_SITE_KEY = siteKey;
    </script>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

    <style is:global>
      :root {
        --accent: 136, 58, 234;
        --accent-light: 224, 204, 250;
        --accent-dark: 49, 10, 101;
        --accent-gradient: linear-gradient(
          45deg,
          rgb(var(--accent)),
          rgb(var(--accent-light)) 30%,
          white 60%
        );
      }
      html {
        font-family: system-ui, sans-serif;
        background: #F8FAFC;
      }
      #member-root {
        min-height: 100vh;
      }
      @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-4px); }
        75% { transform: translateX(4px); }
      }
      .animate-shake {
        animation: shake 0.2s ease-in-out 0s 2;
      }
    </style>
  </head>
  <body>
    <div id="member-root">
      <App client:only="react" />
    </div>
  </body>
</html>
